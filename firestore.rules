rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      // For this specific request, we are using a custom username/password login
      // that signs in anonymously to satisfy Firebase Auth requirements.
      // We'll trust the authenticated session for write access to the config.
      return isAuthenticated();
    }

    // Site Config
    match /config/site {
      allow read: if true;
      allow write: if isAdmin() || !exists(/databases/$(database)/documents/config/site);
    }

    // Admins collection (for storing the custom credentials if needed)
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }

    // Test connection
    match /test/connection {
      allow read: if true;
    }
  }
}
